const express = require("express");
const router = express.Router();
const sql = require("mssql");
const dbConfig = require("../config/dbConfig");

router.put("/synce", async (req, res) => {
    const sql = require("mssql");
    const pool = new sql.ConnectionPool(dbConfig);

    pool.on("error", (err) => {
      console.log("sql errors", err);
    });

    try {
      await pool.connect();
      let result = await pool
        .request()
        .input("MachineID", sql.NVarChar(25), req.body.MachineID)
        .query(`
            IF EXISTS (SELECT * FROM ProductionLogs WHERE MachineID = @MachineID) 
            BEGIN 
                UPDATE ProductionLogs 
                SET LastUpdate = GETDATE() 
                WHERE MachineID = @MachineID 
            END 
            ELSE 
            BEGIN 
                INSERT INTO ProductionLogs (MachineID, LastUpdate) 
                VALUES (@MachineID, GETDATE()) 
            END`)

        .then(result => {
              res.status(200).json({ status: "success", message: "Data synced" });
              })
        .catch(err => {
              res.status(400).json({ status: "error", message: err.message });
              })
    } catch (err) {
      res.status(400).send("catch " + err);
    } finally {
      pool.close();
    }
    sql.on("error", (err) => {
      res.status(400).send("sql " + err);
    });
  });

module.exports = router;
